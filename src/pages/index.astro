---
import BaseLayout from '../layouts/BaseLayout.astro';
import broomfield_logo from '../assets/img/broomfield_co_masthead_logo.png'
import gama_logo from '../assets/img/gama_tabletop_game_association_masthead_logo.png'
import teg_logo from '../assets/img/total_escape_games_masthead_logo.png';

const title = "Designing for Experience | Jason Garvin";
const description = "The professional website for Jason Garvin, owner and Chief Operating Officer of Total Escape Games, web designer, and opinionated thinker.";
const canonicalUrl = "https://jasongarvin.com";
---

<BaseLayout
  description={description}
  title={title}
  canonicalUrl={canonicalUrl}>

  <main id="main-content">

    <section class="hero-content top-of-page transparent-bg">
      <h1 class="hero-header">Hi, I'm Jason</h1>

      <div>
        <h2 class="hero-subtitle">
          <strong>I run Total Escape Games, create websites,</strong>
          and write about business and productivity
        </h2>
      </div>

      <div class="button-container">
        <a class="default-button cta-button" href="/blog/">
          Read my Blog
        </a>
        <a class="secondary-button cta-button" href="/projects/">
          See my Projects
        </a>
      </div>
    </section>

    <!-- Below the cut -->
    <section class="home-gap transparent-bg animate-drop">
      <h2>Thoughtful Blog Posts</h3>
      <p>
        I dig into a variety of topics that span the gap from business
        management to personal growth to technology. Anything that catches my
        attention and fascinates me, really.
      </p>
      <p>
        Here are some of my favorites so far.
      </p>
    </section>

    <section class="preview-grid vertical-space transparent-bg">
      <section class="blog-card active-card animate-slide">
        <h3 class="title-preview centered">
          <a href="/blog/posts/if-your-staff-sucks-a-gama-expo-presentation">If Your Staff Sucks... (GAMA Presentation)</a>
        </h3>
        <div class="blog-card-info">
            <time class="pub-info-preview" datetime="2026-03-07">03/07/2026</time>
        </div>
      </section>

      <section class="blog-card animate-slide">
        <h3 class="title-preview centered">
          <a href="/blog/posts/the-value-of-keeping-a-library">The Value of Keeping a Library</a>
        </h3>
        <div class="blog-card-info">
          <time class="pub-info-preview" datetime="2024-11-30">11/30/2024</time>
        </div>
      </section>

      <section class="blog-card animate-slide">
        <h3 class="title-preview centered">
          <a href="/blog/posts/overcoming-decision-fatigue-strategies-for-business-owners">Overcoming Decision Fatigue: Strategies for Business Owners</a>
        </h3>
        <div class="blog-card-info">
          <time class="pub-info-preview" datetime="2024-07-31">07/31/2024</time>
        </div>
      </section>

      <section class="blog-card animate-slide">
        <h3 class="title-preview centered">
          <a href="/blog/posts/context-switching-destroys-your-effectiveness">Context Switching Destroys your Effectiveness</a>
        </h3>
        <div class="blog-card-info">
          <time class="pub-info-preview" datetime="2024-06-30">06/30/2024</time>
        </div>
      </section>
    </section>

    <aside class="home-block home-gap animate-drop">
      <p class="subtitle">
        Or, find out about what keeps me busy each day
      </p>
      <p class="right-align">
        and what I've learned from it.
      </p>
    </aside>

    <section class="home-block home-gap transparent-bg">
      <section class="brand-container animate-slide">
        <img id="teg-logo" src={teg_logo.src} alt="The Total Escape Games logo" height="80" alt="Total Escape Games" />
        <h2 class="brand-name" hidden>Total Escape Games</h2>
      </section>

      <section class="animate-slide">
        <h3 class="subtitle">Building Local Community</h3>
        <p class="left-align">
          <span>Total Escape Games</span> has been around for 17 years, and
          during that time we've truly become a third space and community hub.
          More than just selling tabletop games, we're a place where people meet
          lifelong friends, connect over shared hobbies, and find representation
          in seeing their favorite items on our shelves.
        </p>
        <p>
          We work tirelessly for our community, and we're always making upgrades.
          Soon we'll transition our point of sale, expand our website, and reach
          new audiences to bring our brand of gaming and community to the web!
        </p>
      </section>

      <aside>
        <ul class="list-emphasis">
          <li class="list-item-emphasis animate-drop">
            <a href="https://totalescapegames.com" target="_blank" rel="external">
              Website
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
          <li class="list-item-emphasis animate-drop">
            <a href="https://instagram.com/totalescapegames" target="_blank" rel="external">
              Instagram
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
          <li class="list-item-emphasis animate-drop">
            <a href="https://discord.gg/R9krk7CVzK" target="_blank" rel="external">
              Discord
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
        </ul>
      </aside>
    </section>

    <section class="home-block home-gap__small transparent-bg">
      <section class="brand-container animate-slide">
        <img id="teg-logo" src={gama_logo.src} alt="The Total Escape Games logo" height="80" alt="GAMA: The Tabletop Game Association" />
        <h2 class="brand-name">Sustainability Committee</h2>
      </section>

      <section class="animate-slide">
        <h3 class="subtitle">Improving Industry Sustainability</h3>
        <p class="left-align">
          I’ve been serving as a retail member of the GAMA Sustainability
          Committee since 2025 to help like-minded retailers bring renewable
          initiatives into their businesses. From highlighting sustainably-made
          games to helping businesses find local recycling facilities for their
          hard-to-recycle materials, we’re bringing sustainability to retailers.
        </p>
        <p>
          We also advise publishers and manufacturers on best practices to
          create renewable, recyclable, and environmentally-friendly board games.
        </p>
      </section>

      <aside>
        <ul class="list-emphasis">
          <li class="list-item-emphasis animate-drop">
            <a href="https://www.gama.org/" target="_blank" rel="external">
              GAMA Website
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
          <li class="list-item-emphasis animate-drop">
            <a href="https://www.gama.org/page/get-involved" target="_blank" rel="external">
              Get Involved
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
        </ul>
      </aside>
    </section>

    <section class="home-block home-gap__small transparent-bg">
      <section class="brand-container animate-slide">
        <img id="teg-logo" src={broomfield_logo.src} alt="The Total Escape Games logo" height="80" alt="The City and County of Broomfield, CO" />
        <h2 class="brand-name">
          Advisory Committee on Environmental Sustainability (ACES)
        </h2>
      </section>

      <section class="animate-slide">
        <h3 class="subtitle">Making Broomfield More Sustainable</h3>
        <p class="left-align">
          I’m a new member of the Broomfield ACES board effective 2026, working
          to bring environmentally-conscious legislation and renewable practices
          to the place where I live.
        </p>
        <p>
          Affecting local change is difficult, but Broomfield is committed, and
          on track, to to hit our Zero Waste goals by 2050, and are working to
          improve our energy efficiency, too.
        </p>
      </section>

      <aside>
        <ul class="list-emphasis">
          <li class="list-item-emphasis animate-drop">
            <a href="https://broomfield.org/3236/Sustainability" target="_blank" rel="external">
              Broomfield Sustainability
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
          <li class="list-item-emphasis animate-drop">
            <a href="https://www.broomfield.org/2855/Advisory-Committee-on-Environmental-Sust" target="_blank" rel="external">
              Information on ACES
              <i class="fa-solid fa-arrow-up-right-from-square"></i>
            </a>
          </li>
        </ul>
      </aside>
    </section>

    <section class="home-gap transparent-bg">
      <h2>My Focus</h2>
      <p>
        We all work best when our tools and environment help support our needs,
        so I bring that user-centric approach to business in order to cultivate
        strong, resilient teams.
      </p>
    </section>

    <aside>
      <div class="home-grid vertical-space">
        <section class="animate-slide">
          <h3 class="subtitle">
            <i class="fa-solid fa-sitemap"></i>
            Operations
          </h3>
          <p>
            I build custom, people-friendly procedures so businesses and
            employees can work efficiently.
          </p>
        </section>
        <section class="animate-slide">
          <h3 class="subtitle">
            <i class="fa-solid fa-chart-line"></i>
            Business Growth
          </h3>
          <p>
            I'm a business owner working to grow my own business, with a focus
            on workplace culture, brand design, and operations.
          </p>
        </section>
        <section class="animate-slide">
          <h3 class="subtitle">
            <i class="fa-solid fa-shield-halved"></i>
            Governance
          </h3>
          <p>
            I maintain a depth of knowledge in compliance, management, and HR,
            and serve on non-profit boards.
          </p>
        </section>
        <section class="animate-slide">
          <h3 class="subtitle">
            <i class="fa-solid fa-code"></i>
            Web Dev
          </h3>
          <p>
            I create websites and interfaces using popular front-end
            frameworks to curate smooth digital experiences.
          </p>
        </section>
      </div>
    </aside>
  </main>
</BaseLayout>

<script src="../assets/scripts/on-scroll-animate.js"></script>
