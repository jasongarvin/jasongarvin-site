---
import BaseLayout from '../layouts/BaseLayout.astro';
import jason_portrait from '../assets/img/jason_at_ruzo_coffee.webp';

const title = "About Me | Jason Garvin";
const description = "Read about Jason Garvin, his experiences as owner of Total Escape Games, involvement in the tabletop gaming industry, and about his featured work.";
const canonicalUrl = "https://jasongarvin.com/about";
---

<BaseLayout
  description={description}
  title={title}
  canonicalUrl={canonicalUrl}>

  <main id="main-content">

    <section class="hero-content top-of-page centered transparent-bg">
      <h1 class="cta-header">About Me</h1>
      <p class="subtitle">
        I'm bringing community and sustainability to long-term business strategy
      </p>
    </section>

    <section class="vertical-space card-flex extended picture-hero">
      <section class="transparent-bg beside-picture-abs">
        <p>
          In this digital age, forging genuine human connection should
          be at the forefront of brand and business design. This is true both in
          cultivating community and also in designing your business procedures.
        </p>
        <p>
          As a business owner and design enthusiast, I strive to blend emerging
          technology with a human-first approach to create amazing experiences.
        </p>
      </section>

      <div class="picture-container centered">
        <img id="my-profile-pic" src={jason_portrait.src} alt="Jason drinking a hot coffee" />
      </div>
    </section>

    <div class="vertical-space card-flex extended">
      <section class="flex-percent-60">
        <h2>
          My History
        </h2>
        <p>
          Motivated by a curiosity about how we think, I earned my degree in
          Psychology from
          <a href="https://www.colostate.edu/" target="_blank" rel="external">Colorado State University</a>.
          This foundation has led me on a 9+ year journey of merging
          psychology principles with operational business strategy, growth
          planning, design, and sustainability.
        </p>
        <p>
          I've worked in a variety of roles, ranging from Office Manager for a
          sole proprietor, HR for a national financial institution, and for tech
          startups leading product design.
        </p>
      </section>

      <section class="box-emphasis">
        <h2>
          <span class="emphasis">My Skills</span>
        </h2>
        <p>
          I've learned to have a diverse skillset as a small business owner.
          Here are the highlights:
        </p>

        <ul class="highlight-list">
          <li>
            Business strategy & operations
          </li>
          <li>
            Small business management
          </li>
          <li>
            User Experience design
          </li>
          <li>
            Creativity & innovation
          </li>
          <li>
            Brand development
          </li>
        </ul>
      </section>
    </div>

    <section class="vertical-space transparent-bg">
      <h2>
        My Vision
      </h2>
      <p>
        As technology continues to advance and its influence grows, I want to
        bring back the power of real interpersonal connection and
        sustainably-designed business practices. My dream is to
        create experiences that bring people together, build communities, and
        take care of our planet all the while.
      </p>
      <p>
        I'm committed to designing these touchpoints with creativity, empathy,
        and focus, ensuring every interaction leaves a lasting, positive
        impact.
      </p>
    </section>

    <section class="vertical-space box-emphasis">
      <h2>Current Roles</h2>

      <ul class="highlight-list">
        <li>
          <a href="https://totalescapegames.com" rel="external">
            Total Escape Games
          </a>
          <span>- Owner / Chief Operating Officer</span>
        </li>
        <li>
          <a href="https://www.gama.org/" rel="external">
            Tabletop Game Association Sustainability Committee
          </a>
          <span>- Retail Subcommittee Member</span>
        </li>
        <li>
          <a href="https://www.broomfield.org/2855/Advisory-Committee-on-Environmental-Sust" rel="external">
            Broomfield Advisory Committee on Environmental Sustainability
          </a>
          <span>- Board Member</span>
        </li>
      </ul>
    </section>

    <section class="buffer">
      <h2>Featured In</h2>

      <ul class="highlight-list">
        <li>
          <a href="https://shoutoutcolorado.com/meet-jason-garvin-small-business-owner/" rel="external">
            Meet Jason Garvin | Small Business Owner
          </a>
          <span>- published in Shoutout Colorado</span>
        </li>
        <li>
          <a href="https://canvasrebel.com/meet-jason-garvin/" rel="external">
            Meet Jason Garvin
          </a>
          <span>- published in Canvas Rebel</span>
        </li>
        <li>
          <a href="https://voyagedenver.com/interview/exploring-life-business-with-jason-garvin-of-total-escape-games/" rel="external">
            Exploring Life & Business with Jason Garvin of Total Escape Games
          </a>
          <span>- published in Voyage Denver</span>
        </li>
        <li>
          And I'm an
          <a href="https://www.wikihow.com/Author/Jason-Garvin" rel="external">
            expert for WikiHow
          </a>
        </li>
      </ul>
    </section>

    <section class="buffer">
      <h2>Appearances</h2>
      <ul class="highlight-list">
        <li>
          <a href="https://youtu.be/qtHus24VUdk?si=tBnqY9YmI-Vz5C4O" rel="external">
            How to Build Trust and Innovation in your Business
          </a>
          <span>- appeared on the TrustBuilt Podcast</span>
        </li>
        <li>
          <a href="https://manaversesaga.com/mvp115-running-a-hands-off-game-store-with-jason-garvin-from-total-escape-games/" rel="external">
            Running a Hands Off Game Store with Jason Garvin from Total Escape Games
          </a>
          <span>- appeared on the Manaverse Saga Podcast</span>
        </li>
      </ul>
    </section>

    <section class="buffer">
      <h2>Guest Writing</h2>
      <p>
        I've guest-written for the
        <a href="https://blog.cardcastle.co/" rel="external">CardCastle</a>
        blog, including two parts to a series on inventory management,
        procedure design, and testing new technologies.
      </p>
      <ul class="highlight-list">
        <li>
          <a href="https://blog.cardcastle.co/if-amazon-ran-a-tcg-singles-business-part-5/" rel="external">
            If Amazon Ran a TCG Singles Business (Part 5)
          </a>
        </li>
        <li>
          <a href="https://blog.cardcastle.co/if-amazon-ran-a-tcg-singles-business-part-4/" rel="external">
            If Amazon Ran a TCG Singles Business (Part 4)
          </a>
        </li>
      </ul>
    </section>
  </main>
</BaseLayout>
